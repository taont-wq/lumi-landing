# === CI/CD (GitHub Secrets) ===
# Set these trong GitHub repo Settings → Secrets and variables → Actions:
# VERCEL_TOKEN:           Lấy từ https://vercel.com/account/tokens
# VERCEL_ORG_ID:          Lấy từ `vercel whoami` hoặc Vercel Dashboard
# VERCEL_PROJECT_ID:      Lấy từ `vercel project ls` hoặc Settings → Project ID
# SUPABASE_ACCESS_TOKEN:  Lấy từ https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF:   Mã ref trong Supabase Dashboard → Project Settings

# === ZALO BOT ===
ZALO_OA_ID=123456789
ZALO_ACCESS_TOKEN=xxx
ZALO_APP_SECRET=xxx
# Webhook secret token (X-Bot-Api-Secret-Token)
ZALO_SECRET=xxx

